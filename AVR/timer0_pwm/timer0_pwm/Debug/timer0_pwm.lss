#define F_CPU 16000000UL
#include <avr/io.h>
void fast_pwm()
{
	TCCR0A|=(1<<WGM00)|(1<<WGM01);// set fast PWM mode
  80:	84 b5       	in	r24, 0x24	; 36
  82:	83 60       	ori	r24, 0x03	; 3
  84:	84 bd       	out	0x24, r24	; 36
	
